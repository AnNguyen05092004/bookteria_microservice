{
    "info": {
        "_postman_id": "2e2f9a03-7638-4a95-a0f7-31ef8db420f2",
        "name": "Bookteria - Chat User Search",
        "description": "Test flow for chat user search via API Gateway: login first, then search users.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:8888/api"
        },
        {
            "key": "username",
            "value": "your_username"
        },
        {
            "key": "password",
            "value": "your_password"
        },
        {
            "key": "keyword",
            "value": "an"
        },
        {
            "key": "token",
            "value": ""
        }
    ],
    "item": [
        {
            "name": "1) Login",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
                },
                "url": {
                    "raw": "{{baseUrl}}/identity/auth/login",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "identity",
                        "auth",
                        "login"
                    ]
                }
            },
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "type": "text/javascript",
                        "exec": [
                            "pm.test('Status code is 200', function () {",
                            "    pm.response.to.have.status(200);",
                            "});",
                            "",
                            "var jsonData = pm.response.json();",
                            "pm.test('Login response has token', function () {",
                            "    pm.expect(jsonData.result).to.have.property('token');",
                            "});",
                            "",
                            "pm.collectionVariables.set('token', jsonData.result.token);"
                        ]
                    }
                }
            ]
        },
        {
            "name": "2) Search Users",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    },
                    {
                        "key": "Authorization",
                        "value": "Bearer {{token}}"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"keyword\": \"{{keyword}}\"\n}"
                },
                "url": {
                    "raw": "{{baseUrl}}/profile/users/search",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "profile",
                        "users",
                        "search"
                    ]
                }
            },
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "type": "text/javascript",
                        "exec": [
                            "pm.test('Status code is 200', function () {",
                            "    pm.response.to.have.status(200);",
                            "});",
                            "",
                            "var jsonData = pm.response.json();",
                            "pm.test('Search response has result array', function () {",
                            "    pm.expect(jsonData).to.have.property('result');",
                            "    pm.expect(jsonData.result).to.be.an('array');",
                            "});"
                        ]
                    }
                }
            ]
        },
        {
            "name": "3) My Profile (debug token)",
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{token}}"
                    }
                ],
                "url": {
                    "raw": "{{baseUrl}}/profile/users/my-profile",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "profile",
                        "users",
                        "my-profile"
                    ]
                }
            }
        }
    ]
}